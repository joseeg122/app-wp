{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/scripts/(.*)",
      "dest": "/scripts/$1"
    },
    {
      "src": "/flappy.css",
      "dest": "/flappy.css"
    },
    {
      "src": "/bg.mp3",
      "dest": "/bg.mp3"
    },
    {
      "src": "/dead.mp3",
      "dest": "/dead.mp3"
    },
    {
      "src": "/(.*)",
      "dest": "/flappy2.html"
    }
  ]
}